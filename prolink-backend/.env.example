# ProLink Backend — Environment Variables

# ========================================
# Database
# ========================================
DATABASE_URL="postgresql://user:password@host:5432/db"
DIRECT_URL="postgresql://user:password@host:5432/db"

# ========================================
# Security
# ========================================
JWT_SECRET=your_super_secret_jwt_key
EMAIL_API_SECRET=PROLINK_INTERNAL_SECRET_888

# ========================================
# Email (SMTP)
# ========================================
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_NOTIFICATIONS_USER=notifications@gmail.com
SMTP_NOTIFICATIONS_PASS=your_app_password

# ========================================
# Cloudinary (File Uploads)
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# Paystack (Payments)
# ========================================
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx

# ========================================
# Environment
# ========================================
NODE_ENV=development
LOG_LEVEL=debug
FRONTEND_ORIGIN=http://localhost:3000

# ========================================
# Database Pool (optional - has sensible defaults)
# ========================================
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ========================================
# Redis (optional - for Socket.IO horizontal scaling)
# ========================================
# REDIS_URL=redis://localhost:6379
